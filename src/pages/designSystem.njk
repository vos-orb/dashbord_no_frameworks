  window[that.widgetId] = that;
})(window);


</script>


  </div>
</div>

<div class="spoiler">
  <div class="header">Дэйт-пикеры</div>
  <div class="contents">

<div class="ui-datepicker" data-range="true">
  <div class="wrapper">
    <input type="text" placeholder="Выберите период" readonly />
  </div>
</div>

<div class="ui-datepicker">
  <div class="wrapper">
    <input type="text" placeholder="Выберите дату" readonly>
  </div>
</div>

  </div>
</div>

  <div class="spoiler">
    <div class="header">Календари</div>
    <div class="contents">

      <div class="ui-calendar"></div>
      <div class="ui-calendar full-width" id="myCalendar"></div>

    </div>
  </div>


  <script type="application/javascript">
    document.addEventListener('DOMContentLoaded', () => {

      //fill calendar with meta
      (function() {
        const calendarElement = document.getElementById('myCalendar');

          calendarElement.addEventListener('calendarinitialized', (e) => {
            e.detail.calendar.setMeta([
              {
                date: new Date('2023-10-15'),
                htmltext: '<span class="event">Event 1</span>'
              },
              {
                date: new Date('2023-10-20'),
                htmltext: '<span class="event">Event 2</span>'
              },
              {
                date: new Date('2026-04-23'),
                htmltext: '<span class="event">much better</span>'
              },
              {
                date: new Date('2026-05-23'),
                htmltext: '<span class="event">very nice</span>'
              }
            ]);
          });
      })();
      // v1 function
      initDropdowns('.dropdown.fruits', {
        data: function() {
          return ['Яблоко', 'Банан', 'Апельсин', 'Груша', 'Виноград'];
        },
        onSelect: function(selectedItem) {
          console.log('Выбран фрукт:', selectedItem);
        }
      });

      // v2 array
      initDropdowns('.dropdown-colors', {
        data: ['Красный', 'Синий', 'Зелёный', 'Жёлтый', 'Фиолетовый'],
        onSelect: function(selectedItem) {
          console.log('Выбран цвет:', selectedItem);
        }
      });

      // v3 request
      initDropdowns('.dropdown-async', {
        data: async function() {
          try {
            const response = await fetch('/api/items');
            const data = await response.json();
            return data.map(item => item.name);
          } catch (error) {
            console.error('Ошибка загрузки данных:', error);
            return ['Ошибка загрузки'];
          }
        },
        onSelect: function(selectedItem) {
          console.log('Выбран элемент:', selectedItem);
        }
      });

      // v4 other
      initDropdowns('.dropdown-complex', {
        data: function() {
          const currentYear = new Date().getFullYear();
          const years = [];
          for (let year = currentYear - 10; year <= currentYear + 5; year++) {
            years.push(year.toString());
          }
          return years;
        },
        onSelect: function(selectedYear) {
          console.log('Выбранный год:', selectedYear);
        }
      });
    });
  </script>
{% endblock %}
