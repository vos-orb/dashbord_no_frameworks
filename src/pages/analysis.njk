{% extends "layout.njk" %}
{% block content %}

<div class="flex-row">
  <div class="flex-column">

    <div class="ui-datepicker analyze-pnl-datepicker" data-range="true">
      <div class="wrapper">
        <input type="text" placeholder="Выберите период" readonly />
      </div>
    </div>

  </div>
  <div class="flex-column">
    <div class="dropdown ddl-strategy">
      <button class="dropdown-toggle">Стратегия</button>
      <div class="dropdown-menu"></div>
    </div>
  </div>
  <div class="flex-column">
    <div class="dropdown ddl-coin">
      <button class="dropdown-toggle">Монета</button>
      <div class="dropdown-menu"></div>
    </div>
  </div>
  <div class="flex-column">
    <div class="dropdown ddl-direction">
      <button class="dropdown-toggle">Направление</button>
      <div class="dropdown-menu"></div>
    </div>
  </div>
  <div class="flex-column">
    <div class="dropdown ddl-trading-series">
      <button class="dropdown-toggle">Торговые серрии</button>
      <div class="dropdown-menu"></div>
    </div>
  </div>
  <div class="flex-column">
    <div class="ui-button primary apply-filters">Применить фильтры</div>
  </div>
</div>

<br />

<div class="spoiler expanded">
  <div class="header">PNL/ROI</div>
  <div class="contents">
    График
  </div>
</div>

<div class="spoiler expanded">
  <div class="header">Детализация</div>
  <div class="contents">

    <div class="ui-calendar full-width trading-calendar"></div>

  </div>
</div>









  <script type="module">
import { getRequest, postRequest } from '@/services/api.js';
let currentStrategy = '';
let currentCoin = '';
let currentDirection = '';
let currentTradingSerie = '';
let currentDatePeriod = [];


function getStrategyResults(response) {
  let strategyNames = response.data.strategy_info.map(s => s.name);
  let coins = response.data.strategy_info.find(s => s.name === strategyNames[0])?.coins || [];

  initDropdowns('.dropdown.ddl-strategy', {
    data: strategyNames,
    multiSelect: true,
    onSelect: function(selectedStrategies) {
      currentStrategy = selectedStrategies;

      coins = [];
      selectedStrategies.forEach(str => {
        let cns = response.data.strategy_info.find(s => s.name === str)?.coins || [];
        coins.push(...cns);
      });

      initDropdowns('.dropdown.ddl-coin', {
        multiSelect: true,
        data: coins,
        onSelect: function(selectedCoins) {
          currentCoin = selectedCoins;
        }
      });

    }
  });
}
document.addEventListener('DOMContentLoaded', () => {

  const getDataForDddls = async function() {
    if ({{ DEBUG }}) {
      //console.log("API_URL", '{{ API_URL }}');
    }
    try {
      const response = await postRequest('/get_strategy_results', {"date_from": "2025-08-21"});
      getStrategyResults(response);
    } catch (error) {
      console.error('Ошибка загрузки данных:', error);
      return ['Ошибка загрузки'];
    }
  };
  const ddlData = getDataForDddls();

  let analyzePNLDatepicker = document.querySelector('.analyze-pnl-datepicker');
  analyzePNLDatepicker.addEventListener('datechange', (e) => {
    let p = e?.detail?.currentValue;
    const [startDate, endDate] = p.split('—').map(date => date.trim());
    currentDatePeriod = [startDate, endDate];
  });

  initDropdowns('.dropdown.ddl-direction', {
    data: ['Long', 'Short'],
    multiSelect: true,
    onSelect: function(selectedItem) {
      currentDirection = selectedItem;
    }
  });
  initDropdowns('.dropdown.ddl-trading-series', {
    data: ['Азия', 'Европа', 'Америка', 'Тихоокеания'],
    multiSelect: true,
    onSelect: function(selectedItem) {
      currentTradingSerie = selectedItem;
    }
  });

  document.querySelector('.apply-filters').addEventListener('click', function(evt) {
    evt.stopPropagation();
    console.warn('currentStrategy,currentCoin',currentStrategy,currentCoin, currentDirection, currentTradingSerie, currentDatePeriod);

    //TODO {"strategy":["oneside_grid_bot"],"symbol":["BTC-USDT"],"direction":["long"],"session":["asia"],"date_from":"2025-08-21","date_to":"2025-09-20"}
  });

  //fill Trading calendar with meta
  (function() {
    const calendarElement = document.querySelector('.ui-calendar.trading-calendar');

    calendarElement.addEventListener('calendarinitialized', (e) => {
      e.detail.calendar.setMeta([
        {
          date: new Date('2023-10-15'),
          htmltext: '<span class="event">Event 1</span>'
        },
        {
          date: new Date('2023-10-20'),
          htmltext: '<span class="event">Event 2</span>'
        },
        {
          date: new Date('2026-04-21'),
          htmltext: '<span class="event">much better WOW</span>'
        },
        {
          date: new Date('2026-05-23'),
          htmltext: '<span class="event">very nice</span>'
        }
      ]);
    });
  })();

});
  </script>
  <script type="application/javascript">
    console.log({{ DEBUG }},"<-:DEBUG");
    document.addEventListener('DOMContentLoaded', () => {

    });
  </script>
{% endblock %}
