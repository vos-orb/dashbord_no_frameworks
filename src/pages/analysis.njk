  </div>
</div>

<br />

<div class="spoiler ">
  <div class="header">PNL/ROI</div>
  <div class="contents">
    <div class="ui-chartjs" id="container_pnl_roi" style="width:100%; height:400px;"></div>
  </div>
</div>

<div class="spoiler ">
  <div class="header">Детализация</div>
  <div class="contents">

    <div class="ui-calendar full-width trading-calendar"></div>

  </div>
</div>
<div class="spoiler expanded">
  <div class="header">Отчёт риск-профиль</div>
  <div class="contents">

    <div class="flex-row">
      <div class="flex-column">
        charts
<div class="ui-chartjs" id="container_cumulative_returns" style="width:100%; height:400px;"></div>
<div class="ui-chartjs" id="container_cumulative_returns_scaled" style="width:100%; height:400px;"></div>
<div class="ui-chartjs" id="container_eoy_returns" style="width:100%; height:400px;"></div>
