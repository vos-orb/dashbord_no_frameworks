      </div>
    </div>

  </div>
</div>

<script type="module">
import { getRequest, postRequest } from '@/services/api.js';
let currentStrategy = '';
let currentCoin = '';
let currentDirection = '';
let currentTradingSerie = '';
let currentDatePeriod = [];
let chartPnl = {};

let chartCumulativeReturns = {};
let chartCumulativeReturnsScaled = {};
let chartEoyReturns = {};
let chartDailyActiveReturns = {};
let chartRollingVolatility = {};
let chartRollingSharpe = {};
let chartRollingSortino = {};
let chartMonthlyReturns = {};
let chartUnderwaterPlot = {};
let chartDrawdownPeriods = {};
let chartReturnQuantiles = {};

function getStrategyResults(response, isUpdate=false) {
  let strategyNames = response.data.strategy_info.map(s => s.name);
  let coins = response.data.strategy_info.find(s => s.name === strategyNames[0])?.coins || [];
  let pnlRoiChartData = response?.data?.pnl_roi_chart;

  if (chartPnl?.series ) {
    chartPnl.series[0].setData(pnlRoiChartData.roi, false); // false, чтобы не перерисовывать сразу
    chartPnl.series[1].setData(pnlRoiChartData.pnl, false);
    chartPnl.series[2].setData(pnlRoiChartData.balance_changing, false);
    chartPnl.series[3].setData(pnlRoiChartData.amount, false);
    chartPnl.redraw();
  }
  if (isUpdate) {return;}
  initDropdowns('.dropdown.ddl-strategy', {
    data: strategyNames,
    multiSelect: true,
    onSelect: function(selectedStrategies) {
      currentStrategy = selectedStrategies;

      coins = [];
      selectedStrategies.forEach(str => {
        let cns = response.data.strategy_info.find(s => s.name === str)?.coins || [];
        coins.push(...cns);
      });

      initDropdowns('.dropdown.ddl-coin', {
        multiSelect: true,
        data: coins,
        onSelect: function(selectedCoins) {
          currentCoin = selectedCoins;
        }
      });

    }
  });
}
document.addEventListener('DOMContentLoaded', () => {

  const getDataForDddls = async function() {
    if ({{ DEBUG }}) {
      //console.log("API_URL", '{{ API_URL }}');
    }
    try {
      const response = await postRequest('/get_strategy_results', {"date_from": "2025-08-21"});
      getStrategyResults(response);
    } catch (error) {
      console.error('Ошибка загрузки данных:', error);
      return ['Ошибка загрузки'];
    }
  };
  const ddlData = getDataForDddls();
  const processResponse = async function(res) {
    let cumulativeReturnsChartData = res?.data?.cumulative_returns_chart;
    let cumulativeReturnsChartScaledData = res?.data?.cumulative_returns_chart_scaled;
    let eoyReturnsChartData = res?.data?.eoy_returns_chart;
    let dailyActiveReturnsChartData = res?.data?.daily_active_returns_chart;
    let rollingVolatilityChartData = res?.data?.rolling_volatility_chart;

    let rollingSharpeChartData = res?.data?.rolling_sharpe_chart;
    let rollingSortinoChartData = res?.data?.rolling_sortino_chart;
    let heatmapReturnChartData = res?.data?.heatmap_return_chart;
    let underwaterPlotChartData = res?.data?.underwater_plot_chart;
    let drowdownPeriodsChartData = res?.data?.drowdown_periods_chart;

    let returnQuantiliesChartData = res?.data?.return_quantilies_chart;

    let distrMontlyReturnsChartData = res?.data?.distribution_of_montly_returns;

    let tablePerformanceIndicators = document.querySelector('.table-performance-indicators');
    tablePerformanceIndicators.addEventListener('tableinitialized', function(e) {
      window.ui_tooltip.methods.initBySelector('.table-performance-indicators .ui-tooltip');
    });
    tablePerformanceIndicators.addEventListener('pagechange', function(e) {
      window.ui_tooltip.methods.initBySelector('.table-performance-indicators .ui-tooltip');
    });

    const dataArr = await res?.data?.metrics?.basic;
    const formattedTPIData = await dataArr.map((item) => ({
      indicators: `<div class="ui-tooltip newbee" data-position="r" data-is-hover="true">
          <div class="container">⚠ ${item.title}</div>
          <div class="tooltip-contents">${item.description}</div>
        </div>`,
      strategy: numberFormatter.format((item.value?.returns)
        ? item.value.returns
        : item.value)
      + ((item.measurement)
         ? ' '+ item.measurement
         : '')
    }));

    new UiTable(tablePerformanceIndicators, formattedTPIData, null, {
      noPagination: true,
      numericColumns: [
        'indicators',
        'strategy'
      ]
    });

    let tableEoyIndicators = document.querySelector('.table-eoy-indicators');
    const dataArrEoyIndicators = await res?.data?.metrics?.eoy;
    const formattedEoyData = await dataArrEoyIndicators.map((item) => ({
      year: item.year,
      return: numberFormatter.format(item.return),
      cumulative: numberFormatter.format(item.cumulative)
    }));

    new UiTable(tableEoyIndicators, formattedEoyData, null, {
      noPagination: true,
      numericColumns: [
        'return',
        'cumulative'
      ]
    });

    let tableDrawdowns = document.querySelector('.table-drawdowns');
    const dataArrDrawdownsIndicators = await res?.data?.metrics?.worst_drawdowns;

    const formattedDrawdownsData = await Promise.all(
      dataArrDrawdownsIndicators.map(async (item) => ({
        started: await dateFormatter(item.started),
        recovered: await dateFormatter(item.recovered),
        drawdown: numberFormatter.format(item.drawdown),
        days: item.days
      }))
    );

    new UiTable(tableDrawdowns, formattedDrawdownsData, null, {
      noPagination: true,
      numericColumns: [
        'drawdown'
      ]
    });


    if (chartCumulativeReturns?.series ) {
      const formattedData = await Promise.all(
        cumulativeReturnsChartData.map(async (item) => [
          await new Date(item.date).getTime(),
          parseFloat(item.value)
        ])
      );
      await chartCumulativeReturns.series[0].setData(formattedData);
    }

    if (chartCumulativeReturnsScaled?.series ) {
      const formattedData2 = await Promise.all(
        cumulativeReturnsChartScaledData.map(async (item) => [
          await new Date(item.date).getTime(),
          parseFloat(item.value)
        ])
      );
      await chartCumulativeReturnsScaled.series[0].setData(formattedData2);
    }

    if (chartEoyReturns?.series ) {
      const formattedData3 = await Promise.all(
        eoyReturnsChartData?.data?.map(item => ({ name: item.date, y: item.value }))
      );
      const formattedData3_1 = await Promise.all(
        (new Array(formattedData3?.length)).fill(eoyReturnsChartData?.threshold)
      )
      await chartEoyReturns.series[0].setData(formattedData3);
      await chartEoyReturns.series[1].setData(formattedData3_1);
    }

    if (chartDailyActiveReturns?.series ) {
      const formattedData4 = await Promise.all(
        dailyActiveReturnsChartData.map(async (item) => [
          await new Date(item.date).getTime(),
          parseFloat(item.value)
        ])
      );
      await chartDailyActiveReturns.series[0].setData(formattedData4);
    }

    if (chartRollingVolatility?.series ) {
      const getThreshold = async () => {
        const t = await rollingVolatilityChartData?.threshold;
        return parseFloat(t?.toFixed(2));
      };
      const getData = async () => {
        const promises = rollingVolatilityChartData?.data.map(async (item) => [
          await new Date(item.date).getTime(),
          parseFloat(item.value)
        ]) || [];
        return Promise.all(promises);
      };
      const [trashy, daty] = await Promise.all([
        getThreshold(),
        getData(),
      ]);
      chartRollingVolatility.yAxis[0].update({
        plotLines: [{
          id: 'threshold-plot-line', // По этому ID Highcharts найдет линию
          color: 'red',
          dashStyle: "Dash",
          value: trashy,    // Обновляем значение
          zIndex: 5,
          label: {
            text: `Уровень: ${trashy}`, // Обновляем текст
            align: 'right',
            style: {
              color: 'red'
            }
          }
        }]
      });
      await chartRollingVolatility.series[0].setData(daty);
    }

    if (chartRollingSharpe?.series ) {
      const getThreshold = async () => {
        const t = await rollingSharpeChartData?.threshold;
        return parseFloat(t?.toFixed(2));
      };
      const getData = async () => {
        const promises = rollingSharpeChartData?.data.map(async (item) => [
          await new Date(item.date).getTime(),
          parseFloat(item.value)
        ]) || [];
        return Promise.all(promises);
      };
      const [trashy, daty] = await Promise.all([
        getThreshold(),
        getData(),
      ]);
      chartRollingSharpe.yAxis[0].update({
        plotLines: [{
          id: 'threshold-plot-line2', // По этому ID Highcharts найдет линию
          color: 'red',
          dashStyle: "Dash",
          value: trashy,    // Обновляем значение
          zIndex: 5,
          label: {
            text: `Уровень: ${trashy}`, // Обновляем текст
            align: 'right',
            style: {
              color: 'red'
            }
          }
        }]
      });
      await chartRollingSharpe.series[0].setData(daty);
    }

    if (chartRollingSortino?.series ) {
      const getThreshold = async () => {
        const t = await rollingSortinoChartData?.threshold;
        return parseFloat(t?.toFixed(2));
      };
      const getData = async () => {
        const promises = rollingSortinoChartData?.data.map(async (item) => [
          await new Date(item.date).getTime(),
          parseFloat(item.value)
        ]) || [];
        return Promise.all(promises);
      };
      const [trashy, daty] = await Promise.all([
        getThreshold(),
        getData(),
      ]);
      chartRollingSortino.yAxis[0].update({
        plotLines: [{
          id: 'threshold-plot-line3', // По этому ID Highcharts найдет линию
          color: 'red',
          dashStyle: "Dash",
          value: trashy,    // Обновляем значение
          zIndex: 5,
          label: {
            text: `Уровень: ${trashy}`, // Обновляем текст
            align: 'right',
            style: {
              color: 'red'
            }
          }
        }]
      });
      await chartRollingSortino.series[0].setData(daty);
    }

    if (chartMonthlyReturnsOptions?.series ) {
      const years = Array.from(new Set(heatmapReturnChartData.map(el => el.year)));
      const months = ["ЯНВ", "ФЕВ", "МАРТ", "АПР", "МАЙ", "ИЮНЬ", "ИЮЛЬ", "АВГ", "СЕН", "ОКТ", "НОЯБ", "ДЕК"];

      const formattedData = heatmapReturnChartData.map(item => [
        item.month - 1,           // X: индекс месяца
        years.indexOf(item.year), // Y: индекс года
        item.value                // Значение
      ]);

      chartMonthlyReturns.update({
        xAxis: {
          categories: months
        },
        yAxis: {
          categories: years
        },
        series: [{
          data: formattedData
        }],
        tooltip: {
          formatter: function() {
            const monthName = this.series.xAxis.categories[this.point.x];
            const yearName = this.series.yAxis.categories[this.point.y];
            const val = this.point.value;

            return `${yearName} ${monthName} - <b>${val}</b>`;
          }
        },
      }, true, true);
    }

    if (chartUnderwaterPlot?.series ) {
      const getThreshold = async () => {
        const t = await underwaterPlotChartData?.threshold;
        return parseFloat(t?.toFixed(2));
      };
      const getData = async () => {
        const promises = underwaterPlotChartData?.data.map(async (item) => [
          await new Date(item.date).getTime(),
          parseFloat(item.value)
        ]) || [];
        return Promise.all(promises);
      };
      const [trashy, daty] = await Promise.all([
        getThreshold(),
        getData(),
      ]);
      chartUnderwaterPlot.yAxis[0].update({
        plotLines: [{
          id: 'threshold-plot-line4', // По этому ID Highcharts найдет линию
          color: 'red',
          dashStyle: "Dash",
          value: trashy,    // Обновляем значение
          zIndex: 5,
          label: {
            text: `Уровень: ${trashy}`, // Обновляем текст
            align: 'right',
            style: {
              color: 'red'
            }
          }
        }]
      });
      await chartUnderwaterPlot.series[0].setData(daty);
    }

    if (chartDrawdownPeriods?.series ) {
      const getData = async () => {
        const promises = drowdownPeriodsChartData?.data.map(async (item) => [
          await new Date(item.date).getTime(),
          parseFloat(item.value)
        ]) || [];
        return Promise.all(promises);
      };
      const getSdata = async () => {
        const data = drowdownPeriodsChartData.data;
        const periods = drowdownPeriodsChartData.periods;

        const yValues = data.map(item => item.value);
        const yMin = Math.min(...yValues);
        const yMax = Math.max(...yValues);

        const allDates = Array.from(new Set([
          ...data.map(el => el.date),
          ...periods.map(el => el.end_date),
          ...periods.map(el => el.start_date),
        ])).sort((prev, next) => new Date(prev).getTime() - new Date(next).getTime());

        const seriesData = periods.map((el) => ({
          x: allDates.indexOf(el.start_date),
          x2: allDates.indexOf(el.end_date),
          y: yMin + (yMax - yMin) / 2,
          pointRange: 100,
          color: "rgba(255, 0, 0, 0.15)",
        }));

        return { seriesData, allDates, yMin, yMax };
      };

      const [daty, { seriesData: sData, allDates, yMin, yMax }] = await Promise.all([
        getData(),
        getSdata(),
      ]);
      await chartDrawdownPeriods.series[0].setData(daty);
      await chartDrawdownPeriods.series[1].setData(sData);
      await chartDrawdownPeriods?.update({
        xAxis: {
          categories:allDates,
          labels: {
            formatter: function() {
              const d = new Date(this.value);
              if (isNaN(d.getTime())) return this.value;

              return d.toLocaleDateString('ru-RU', {
                day: '2-digit',
                month: '2-digit',
                year: '2-digit'
              });
            }
          }
        },
        yAxis: {
          min: yMin,
          max: yMax,
          title: {
            text: null
          }
        },
      });
    }

    if (chartReturnQuantiles?.series) {
      let chartData = returnQuantiliesChartData;
      const scatterData = [
        ...chartData.daily.map((value, i) => ({ x: 0, y: value, name: 'Daily' })),    // Сдвигаем точки daily влево
        ...chartData.weekly.map((value, i) => ({ x: 1, y: value, name: 'Weekly' })),   // Сдвигаем точки weekly влево
        ...chartData.monthly.map((value, i) => ({ x: 2, y: value, name: 'Monthly' })), // и т. д.
        ...chartData.quarterly.map((value, i) => ({ x: 3, y: value, name: 'Quarterly' })),
        ...chartData.yearly.map((value, i) => ({ x: 4, y: value, name: 'Yearly' })),
      ];
      const candleData = [
        {
          name: 'Daily',
          x: 0,
          open: chartData.mean.daily,
          high: Math.max(chartData.mean.daily, chartData.median.daily),
          low: Math.min(chartData.mean.daily, chartData.median.daily),
          close: chartData.median.daily,
        },
        {
          name: 'Weekly',
          x: 1,
          open: chartData.mean.weekly,
          high: Math.max(chartData.mean.weekly, chartData.median.weekly),
          low: Math.min(chartData.mean.weekly, chartData.median.weekly),
          close: chartData.median.weekly,
        },
        {
          name: 'Monthly',
          x: 2,
          open: chartData.mean.monthly,
          high: Math.max(chartData.mean.monthly, chartData.median.monthly),
          low: Math.min(chartData.mean.monthly, chartData.median.monthly),
          close: chartData.median.monthly,
        },
        {
          name: 'Quarterly',
          x: 3,
          open: chartData.mean.quarterly,
          high: Math.max(chartData.mean.quarterly, chartData.median.quarterly),
          low: Math.min(chartData.mean.quarterly, chartData.median.quarterly),
          close: chartData.median.quarterly,
        },
        {
          name: 'Yearly',
          x: 4,
          open: chartData.mean.yearly,
          high: Math.max(chartData.mean.yearly, chartData.median.yearly),
          low: Math.min(chartData.mean.yearly, chartData.median.yearly),
          close: chartData.median.yearly,
        },
      ];
      await chartReturnQuantiles.series[0].setData(
        candleData.map((item, index) => ({
          name: item.name,
          open: item.open,
          high: item.high,
          low: item.low,
          close: item.close,
          x: index
        }))
      );
      await chartReturnQuantiles.series[1].setData(scatterData);
      await chartReturnQuantiles?.update({
        xAxis: {
          type: 'category',
          categories: candleData.map(item => item.name),
          labels: {
            formatter: function(data) {
              return `${candleData[data.pos].name}`;
            }
          }
        },
      });
    }

  };

  const getDataForQsReports = async function() {
    try {
      //const response = await postRequest('/analys/get_strategy_qs_report', {
      //const response = await postRequest('/get_strategy_qs_report', {"date_from":"2025-08-21"});
      /*console.log('keys', Object.keys(response?.data));
      console.log('keys returns', Object.keys(response?.data?.returns));
      console.log('keys metrics', Object.keys(response?.data?.metrics));*/
      //processResponse(response);
      processResponse(testmetrics);

    } catch (error) {
      console.error('Ошибка загрузки данных:', error);

    }
