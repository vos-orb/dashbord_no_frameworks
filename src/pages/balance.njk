import { getRequest, postRequest } from '@/services/api.js';

document.addEventListener('DOMContentLoaded', () => {
  // PnL
  initDropdowns('.dropdown.users-pnl', {
    data: async function() {
      if ({{ DEBUG }}) {
        console.log("API_URL", '{{ API_URL }}');
        return ["user1","user2","user3","user4"];
      }
      try {
        const response = await fetch('{{ API_URL }}/filter/user_name_lead');
        const dta = await response?.json();
        return dta.map(item => item.name);
      } catch (error) {
        console.error('Ошибка загрузки данных:', error);
        return ['Ошибка загрузки'];
      }
    },
    onSelect: async function (selectedItem) {
      console.log('Выбран Пользак:', selectedItem);
      const response = await postRequest('/get_pnl_roi_for_user', { "account": selectedItem } );
      console.log('PnL data:', response);
    }
  });
  let pnlPeriodDatepicker = document.querySelector('.pnl-period-datepicker');
  let pnlPeriodRadioGroup = document.querySelector('.pnl-period');
  pnlPeriodRadioGroup.addEventListener('radiochange', (e) => {
    if (!e?.detail?.value) {
      return false;
    }
    if (e?.detail?.value === 'all') {
      pnlPeriodDatepicker._datepicker.clearSelection();
      return;
    }
    let tr = {
      'all': null,
      '30days': 30,
      '90days': 90,
      '180days': 180,
    }
    // select period in date-picker
    pnlPeriodDatepicker._datepicker.setPeriod(tr[e.detail.value]);
  });
