{% extends "layout.njk" %}
{% block content %}
<div class="spoiler expanded">
  <div class="header">PnL/ROI Spoiler</div>
  <div class="contents">

    <div class="dropdown users-pnl">
      <button class="dropdown-toggle">Выберите пользователя</button>
      <div class="dropdown-menu"></div>
    </div>

    <div class="ui-radio-group long-button pnl-period">
      <div class="ui-radio" data-radio="pnl_period" data-value="all">Весь период</div>
      <div class="ui-radio" data-radio="pnl_period" data-value="30days">30 дней</div>
      <div class="ui-radio" data-radio="pnl_period" data-value="90days">90 дней</div>
      <div class="ui-radio" data-radio="pnl_period" data-value="180days">180 дней</div>
    </div>

    <div class="ui-datepicker pnl-period-datepicker" data-range="true">
      <div class="wrapper">
        <input type="text" placeholder="Выберите период" readonly />
      </div>
    </div>
    <br />
    <br />
    <div class="ui-chartjs" id="container_pnl_roi" style="width:100%; height:400px;"></div>
  </div>
</div>

<div class="spoiler expanded">
  <div class="header">Баланс</div>
  <div class="contents">

    <div class="dropdown users-balance">
      <button class="dropdown-toggle">Выберите пользователя</button>
      <div class="dropdown-menu"></div>
    </div>

    <div class="ui-radio-group long-button balance-period">
      <div class="ui-radio" data-radio="balance_period" data-value="all">Весь период</div>
      <div class="ui-radio" data-radio="balance_period" data-value="30days">30 дней</div>
      <div class="ui-radio" data-radio="balance_period" data-value="90days">90 дней</div>
      <div class="ui-radio" data-radio="balance_period" data-value="180days">180 дней</div>
    </div>

    <div class="ui-datepicker balance-period-datepicker" data-range="true">
      <div class="wrapper">
        <input type="text" placeholder="Выберите период" readonly />
      </div>
    </div>
    <br />
    <br />
    <div class="ui-chartjs" id="container_balance" style="width:100%; height:400px;"></div>

  </div>
</div>

<div class="spoiler expanded">
  <div class="header">Баланс и инвесторы</div>
  <div class="contents">

    <div class="dropdown users-balance-inv">
      <button class="dropdown-toggle">Выберите пользователя</button>
      <div class="dropdown-menu"></div>
    </div>
<br />

<div class="flex-row">
  <div class="flex-column">
    <h3>Баланс инвестора</h3>
    {# TODO }ОТКУДА БРАТЬ НАЧАЛЬНЫЙ БАЛАНС И ТЕКУЩИЙ БАЛАНС#}
    <div class="table-component balance-of-investor">
      <div class="search-container">
        <input class="inp search" type="text" placeholder="Поиск..." autocomplete="off">
        <div class="autocomplete-items"></div>
      </div>
      <div class="table-container">
        <table>
          <thead>
          <tr>
            <th data-column="date">Дата</th>
            <th data-column="avg">AVG ???</th>
          </tr>
          </thead>
          <tbody class="table-body">
          <tr>
            <td><div class="skeleton" style="height: 40px;"></div></td>
            <td><div class="skeleton" style="height: 40px;"></div></td>
          </tr>
          </tbody>
        </table>
      </div>
      <div class="pagination">
        <button class="btn prev-page" disabled>Назад</button>
        <span class="page-info">Страница 1 из 1</span>
        <button class="btn next-page">Вперёд</button>
      </div>
    </div>
  </div>
  <div class="flex-column">
    <h3>История пополнений</h3>
    <div class="table-component history-pop-up">
      <div class="search-container">
        <input class="inp search" type="text" placeholder="Поиск..." autocomplete="off">
        <div class="autocomplete-items"></div>
      </div>
      <div class="table-container">
        <table>
          <thead>
          <tr>
            <th data-column="account_name">Аккаунт</th>
            <th data-column="amount">Объём</th>
            <th data-column="datetime">Дата</th>
          </tr>
          </thead>
          <tbody class="table-body">
          <tr>
            <td><div class="skeleton" style="height: 40px;"></div></td>
            <td><div class="skeleton" style="height: 40px;"></div></td>
            <td><div class="skeleton" style="height: 40px;"></div></td>
          </tr>
          </tbody>
        </table>
      </div>
      <div class="pagination">
        <button class="btn prev-page" disabled>Назад</button>
        <span class="page-info">Страница 1 из 1</span>
        <button class="btn next-page">Вперёд</button>
      </div>
    </div>
  </div>
  <div class="flex-column">
    <h3>История изменения баланса</h3>
    <div class="table-component get-filter-and-compute-daily-diffs">
      <div class="search-container">
        <input class="inp search" type="text" placeholder="Поиск..." autocomplete="off">
        <div class="autocomplete-items"></div>
      </div>
      <div class="table-container">
        <table>
          <thead>
          <tr>
            <th data-column="day">День</th>
            <th data-column="account_name">Аккаунт</th>
            <th data-column="start_balance">Начальный баланс</th>
            <th data-column="end_balance">Текущий баланс</th>
            <th data-column="diff">PnL</th>
          </tr>
          </thead>
          <tbody class="table-body">
          <tr>
            <td><div class="skeleton" style="height: 40px;"></div></td>
            <td><div class="skeleton" style="height: 40px;"></div></td>
            <td><div class="skeleton" style="height: 40px;"></div></td>
            <td><div class="skeleton" style="height: 40px;"></div></td>
            <td><div class="skeleton" style="height: 40px;"></div></td>
          </tr>
          </tbody>
        </table>
      </div>
      <div class="pagination">
        <button class="btn prev-page" disabled>Назад</button>
        <span class="page-info">Страница 1 из 1</span>
        <button class="btn next-page">Вперёд</button>
      </div>
    </div>
  </div>
</div>
  {# }Баланс инвестора Сумма текущего баланса 85723485,33$ ТАБЛИЦА
    Аккаунт/Начальный баланс ($)/Текущий баланс($)
      /api/get_filter_and_compute_daily_diff
  История пополнений ТАБЛИЦА
    Аккаунт/Объём ($)/Дата
      /api/get_history_top_up
  История изменений баланса ТАБЛИЦА
    Аккаунт/Начальный баланс ($)/Текущий баланс($)/PnL/Начало периода/Конец периода
      /api/get_balance_diff
    #}
  </div>
</div>







