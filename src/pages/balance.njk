{% extends "layout.njk" %}
{% block content %}
<div class="spoiler expanded">
  <div class="header">PnL/ROI Spoiler</div>
  <div class="contents">

    <div class="dropdown users-pnl">
      <button class="dropdown-toggle">Выберите пользователя</button>
      <div class="dropdown-menu"></div>
    </div>

    <div class="ui-radio-group long-button pnl-period">
      <div class="ui-radio selected" data-radio="pnl_period" data-value="all">Весь период</div>
      <div class="ui-radio" data-radio="pnl_period" data-value="30days">30 дней</div>
      <div class="ui-radio" data-radio="pnl_period" data-value="90days">90 дней</div>
      <div class="ui-radio" data-radio="pnl_period" data-value="180days">180 дней</div>
    </div>

    <div class="ui-datepicker pnl-period-datepicker" data-range="true">
      <div class="wrapper">
        <input type="text" placeholder="Выберите период" readonly />
      </div>
    </div>
    <br />
    <br />
    <div class="ui-chartjs" id="container_pnl_roi" style="width:100%; height:400px;"></div>
    <div class="skeleton hidden" style="width:100%; height:400px;"></div>
  </div>
</div>

<div class="spoiler expanded">
  <div class="header">Баланс</div>
  <div class="contents">

    <div class="dropdown users-balance">
      <button class="dropdown-toggle">Выберите пользователя</button>
      <div class="dropdown-menu"></div>
    </div>

    <div class="ui-radio-group long-button balance-period">
      <div class="ui-radio selected" data-radio="balance_period" data-value="all">Весь период</div>
      <div class="ui-radio" data-radio="balance_period" data-value="30days">30 дней</div>
      <div class="ui-radio" data-radio="balance_period" data-value="90days">90 дней</div>
      <div class="ui-radio" data-radio="balance_period" data-value="180days">180 дней</div>
    </div>

    <div class="ui-datepicker balance-period-datepicker" data-range="true">
      <div class="wrapper">
        <input type="text" placeholder="Выберите период" readonly />
      </div>
    </div>
    <br />
    <br />
    <div class="ui-chartjs" id="container_balance" style="width:100%; height:400px;"></div>

  </div>
</div>

<div class="spoiler expanded">
  <div class="header">Баланс и инвесторы</div>
  <div class="contents">

    <div class="dropdown users-balance-inv">
      <button class="dropdown-toggle">Выберите пользователя</button>
      <div class="dropdown-menu"></div>
    </div>
<br />

<div class="flex-row">
  <div class="flex-column">
    <h3>Баланс инвестора</h3>
    {# TODO }ОТКУДА БРАТЬ НАЧАЛЬНЫЙ БАЛАНС И ТЕКУЩИЙ БАЛАНС#}
    <div class="table-component balance-of-investor">
      <div class="search-container">
        <input class="inp search" type="text" placeholder="Поиск..." autocomplete="off">
        <div class="autocomplete-items"></div>
      </div>
      <div class="table-container">
        <table>
          <thead>
          <tr>
            <th data-column="account_name">Аккаунт</th>
            <th data-column="first_balance">Начальный баланс</th>
            <th data-column="last_balance">Текущий баланс</th>
          </tr>
          </thead>
          <tbody class="table-body">
          <tr>
            <td><div class="skeleton" style="height: 40px;"></div></td>
            <td><div class="skeleton" style="height: 40px;"></div></td>
            <td><div class="skeleton" style="height: 40px;"></div></td>
          </tr>
          </tbody>
        </table>
      </div>
      <div class="pagination">
        <button class="btn prev-page" disabled>Назад</button>
        <span class="page-info">Страница 1 из 1</span>
        <button class="btn next-page">Вперёд</button>
      </div>
    </div>
  </div>
  <div class="flex-column">
    <h3>История пополнений</h3>
    <div class="table-component history-pop-up">
      <div class="search-container">
        <input class="inp search" type="text" placeholder="Поиск..." autocomplete="off">
        <div class="autocomplete-items"></div>
      </div>
      <div class="table-container">
        <table>
          <thead>
          <tr>
            <th data-column="account_name">Аккаунт</th>
            <th data-column="amount">Объём</th>
            <th data-column="datetime">Дата</th>
          </tr>
          </thead>
          <tbody class="table-body">
          <tr>
            <td><div class="skeleton" style="height: 40px;"></div></td>
            <td><div class="skeleton" style="height: 40px;"></div></td>
            <td><div class="skeleton" style="height: 40px;"></div></td>
          </tr>
          </tbody>
        </table>
      </div>
      <div class="pagination">
        <button class="btn prev-page" disabled>Назад</button>
        <span class="page-info">Страница 1 из 1</span>
        <button class="btn next-page">Вперёд</button>
      </div>
    </div>
  </div>
  <div class="flex-column">
    <h3>История изменения баланса</h3>
    <div class="table-component get-filter-and-compute-daily-diffs">
      <div class="search-container">
        <input class="inp search" type="text" placeholder="Поиск..." autocomplete="off">
        <div class="autocomplete-items"></div>
      </div>
      <div class="table-container">
        <table>
          <thead>
          <tr>
            <th data-column="day">День</th>
            <th data-column="account_name">Аккаунт</th>
            <th data-column="start_balance">Начальный баланс</th>
            <th data-column="end_balance">Текущий баланс</th>
            <th data-column="diff">PnL</th>
          </tr>
          </thead>
          <tbody class="table-body">
          <tr>
            <td><div class="skeleton" style="height: 40px;"></div></td>
            <td><div class="skeleton" style="height: 40px;"></div></td>
            <td><div class="skeleton" style="height: 40px;"></div></td>
            <td><div class="skeleton" style="height: 40px;"></div></td>
            <td><div class="skeleton" style="height: 40px;"></div></td>
          </tr>
          </tbody>
        </table>
      </div>
      <div class="pagination">
        <button class="btn prev-page" disabled>Назад</button>
        <span class="page-info">Страница 1 из 1</span>
        <button class="btn next-page">Вперёд</button>
      </div>
    </div>
  </div>
</div>
  </div>
</div>



  <script type="module">
import { getRequest, postRequest } from '@/services/api.js';

document.addEventListener('DOMContentLoaded', () => {
  //charts
  let chartPnl = {};
  let chartBalance = {};
  // PnL
  initDropdowns('.dropdown.users-pnl', {
    data: async function() {
      if ({{ DEBUG }}) {
        console.log("API_URL", '{{ API_URL }}');
        //return ["user1","user2","user3","user4"];
      }
      try {
        const response = await getRequest('/filter/user_name_lead');
        return response;
      } catch (error) {
        console.error('Ошибка загрузки данных:', error);
        return ['Ошибка загрузки'];
      }
    },
    onSelect: async function (selectedItem) {
      const response = await postRequest('/get_pnl_roi_for_user', { "account": selectedItem } );
      if (chartPnl?.series ) {
        chartPnl?.update({ //fill the chart
          xAxis:{
            categories:response?.x
          },
          series:[
            {name:"PnL ($)", data:response?.series?.pnl},
            {name:"ROI (%)", data:response?.series?.roi}
          ]
        });
      }
    }
  });
  let pnlPeriodDatepicker = document.querySelector('.pnl-period-datepicker');
  let pnlPeriodRadioGroup = document.querySelector('.pnl-period');
  pnlPeriodRadioGroup.addEventListener('radiochange', (e) => {
    if (!e?.detail?.value) {
      return false;
    }
    if (e?.detail?.value === 'all') {
      pnlPeriodDatepicker._datepicker.clearSelection();
      return;
    }
    let tr = {
      'all': null,
      '30days': 30,
      '90days': 90,
      '180days': 180,
    }
    // select period in date-picker
    pnlPeriodDatepicker._datepicker.setPeriod(tr[e.detail.value]);
  });
  pnlPeriodDatepicker.addEventListener('datechange', (e) => {
    console.warn('PL DATE CHANGED, e.detail', e.detail);
    //TODO apply date filter to chart

  });
  //Balance
  initDropdowns('.dropdown.users-balance', {
    data: async function() {
      if ({{ DEBUG }}) {
        //return ["user1","user2","user3","user4","user5","user6"];
      }
      try {
        return await getRequest('/filter/user_name');
      } catch (error) {
        console.error('Ошибка загрузки данных:', error);
        return ['Ошибка загрузки'];
      }
    },
    onSelect: async function (selectedItem) {
      const response = await postRequest('/get_data_balance_user', { "user": selectedItem } );
      console.log('Balance data:', response);
      // aggregate data and  fill the chart
      const formattedData = await Promise.all(
        response.map(async (item) => [
          await dateFormatter(item.date),
          parseFloat(item.avg)
        ])
      );
      await chartBalance.series[0].setData(formattedData);
    }
  });
  let balancePeriodRadioGroup = document.querySelector('.balance-period');
  let balancePeriodDatepicker = document.querySelector('.balance-period-datepicker');
  balancePeriodRadioGroup.addEventListener('radiochange', (e) => {
    if (!e?.detail?.value) {
      return false;
    }
    if (e?.detail?.value === 'all') {
      balancePeriodDatepicker._datepicker.clearSelection();
      return;
    }
    let tr = {
      'all': null,
      '30days': 30,
      '90days': 90,
      '180days': 180,
    }
    // select period in date-picker
    balancePeriodDatepicker._datepicker.setPeriod(tr[e.detail.value]);
  });
  balancePeriodDatepicker.addEventListener('datechange', (e) => {
    console.warn('BALANCE DATE CHANGED, e.detail', e.detail);
    //TODO apply date filter to chart

  });

  // Balance and Investors
  initDropdowns('.dropdown.users-balance-inv', {
    data: async function() {
      if ({{ DEBUG }}) {
        //return ["user1","user2","user3","user4","user5","user6"];
      }
      try {
        return [...await getRequest('/filter/user_name'),'all'];
      } catch (error) {
        console.error('Ошибка загрузки данных:', error);
        return ['Ошибка загрузки'];
      }
    },
    onSelect: async function (selectedItem) {
      let tableGFCDF = await document.querySelector('.table-component.get-filter-and-compute-daily-diffs');
      let tableHPU = await document.querySelector('.table-component.history-pop-up');
      let tableBOI = await document.querySelector('.table-component.balance-of-investor');
      // fill the grids
      try {
        const responseTopUp = await postRequest('/get_history_top_up', { "name_acc": selectedItem } );
        const formattedTopUpData = await Promise.all(
          responseTopUp.map( async (item) => ({
              account_name: item.account_name,
              amount: numberFormatter.format(item.amount),
              datetime: await dateFormatter(item.datetime)
          }))
        );
        const responseBalanceDiff = await postRequest('/get_balance_diff_user', { "name_acc": selectedItem } );
        const formattedBalanceDiffData = await responseBalanceDiff.map((item) => ({
          account_name: item.account_name,
          first_balance: numberFormatter.format(item.first_balance),
          last_balance: numberFormatter.format(item.last_balance)
        }));
        const responseGFCDF = await postRequest('/get_filter_and_compute_daily_diffs', { "name_account": selectedItem } );
        const formattedGFCDFData = await responseGFCDF[0]?.items.map((item) => ({
          day: item.day,
          account_name: item.account_name,
          start_balance: numberFormatter.format(Number(item.start_balance)),
          end_balance: numberFormatter.format(Number(item.end_balance)),
          diff: numberFormatter.format(Number(item.diff))
        }));

        new UiTable(tableGFCDF, formattedGFCDFData, 10, {
          numericColumns: [
            'start_balance',
            'end_balance',
            'diff'
          ]
        });
        new UiTable(tableHPU, formattedTopUpData, 10, {
          numericColumns: [
            'amount'
          ]
        });
        new UiTable(tableBOI, formattedBalanceDiffData, 10, {
          numericColumns: [
            'first_balance',
            'last_balance'
          ]
        });

      } catch(err) {
        console.log('ERRRORROROR', err)
      }
    }
  });

  const chartPnlStructure = {
    "chart": {
      "type": "area",
      "backgroundColor": "transparent",
      "borderRadius": 16,
      "spacing": [
        30,
        20,
        30,
        20
      ]
    },
    "title": {
      text: null
    },
    "xAxis": {
      "categories": [],
      "labels": {
        "style": {
          "color": "#64748b",
          "fontSize": "12px"
        }
      },
      "crosshair": {
        "width": 1,
        "color": "#e2e8f0"
      },
      "lineColor": "#e2e8f0"
    },
    "yAxis": [
      {
        "title": {
          "text": "PnL ($)",
          "style": {
            "color": "#64748b",
            "fontSize": "13px",
            "fontWeight": 500
          }
        },
        "labels": {
          "style": {
            "color": "#64748b",
            "fontSize": "12px"
          },
          "x": -8
        }
      },
      {
        "title": {
          "text": "ROI (%)",
          "style": {
            "color": "#64748b",
            "fontSize": "13px",
            "fontWeight": 500
          }
        },
        "labels": {
          "style": {
            "color": "#64748b",
            "fontSize": "12px"
          },
          "x": 8
        },
        "opposite": true
      }
    ],
    "tooltip": {
      "shared": true,
      "valueDecimals": 2,
      "backgroundColor": "rgba(255, 255, 255, 0.96)",
      "style": {
        "color": "#1e293b",
        "fontSize": "13px",
        "fontWeight": 500
      },
      "borderRadius": 12,
      "padding": 16
    },
    "plotOptions": {
      "area": {
        "marker": {
          "radius": 4,
          "fillColor": "#ffffff",
          "lineWidth": 2
        },
        "lineWidth": 2
      }
    },
    "series": [
      {
        "name": "PnL ($)",
        "type": "area",
        "data": [],
        "yAxis": 0,
        "color": "#7c3aed",
        "fillColor": {
          "linearGradient": {
            "x1": 0,
            "y1": 0,
            "x2": 0,
            "y2": 1
          },
          "stops": [
            [
              0,
              "#7c3aed33"
            ],
            [
              1,
              "#7c3aed05"
            ]
          ]
        },
        "lineColor": "#7c3aed",
        "marker": {
          "lineColor": "#7c3aed"
        }
      },
      {
        "name": "ROI (%)",
        "type": "area",
        "data": [],
        "yAxis": 1,
        "color": "#0891b2",
        "fillColor": {
          "linearGradient": {
            "x1": 0,
            "y1": 0,
            "x2": 0,
            "y2": 1
          },
          "stops": [
            [
              0,
              "#0891b233"
            ],
            [
              1,
              "#0891b205"
            ]
          ]
        },
        "lineColor": "#0891b2",
        "marker": {
          "lineColor": "#0891b2"
        },
        "dashStyle": "Dash"
      }
    ],
    "credits": {
      "enabled": false
    },
    "responsive": {
      "rules": [
        {
          "condition": {
            "maxWidth": 600
          },
          "chartOptions": {
            "legend": {
              "layout": "horizontal",
              "align": "center",
              "verticalAlign": "bottom"
            }
          },
          "_id": "highcharts-yg1mzm2-25"
        }
      ]
    }
  };
  chartPnl = Highcharts.chart('container_pnl_roi', chartPnlStructure);

  const chartBalanceStructure = {
    "chart": {
      "type": "area",
      "backgroundColor": 'transparent',
      "borderRadius": 16,
      "spacing": [
        30,
        20,
        30,
        20
      ]
    },
    "title": {
      text: null
    },
    "xAxis": {
      "type": 'datetime',
      "categories": [],
      "labels": {
        "format": '{value:%Y-%m-%d}',
        "padding": 7,
        "style": {
          "color": "#64748b",
          "fontSize": "12px"
        }
      },
      "crosshair": {
        "width": 1,
        "color": "#e2e8f0"
      },
      "lineColor": "#e2e8f0"
    },
    "yAxis": [
      {
        "title": {
          "text": "Balance",
          "style": {
            "color": "#64748b",
            "fontSize": "13px",
            "fontWeight": 500
          }
        },
        "labels": {
          "style": {
            "color": "#64748b",
            "fontSize": "12px"
          },
          "x": -8
        }
      }
    ],
    "tooltip": {
      "shared": true,
      "valueDecimals": 2,
      "xDateFormat": '%Y-%m-%d',
      "backgroundColor": "rgba(255, 255, 255, 0.96)",
      "style": {
        "color": "#1e293b",
        "fontSize": "13px",
        "fontWeight": 500
      },
      "borderRadius": 12,
      "padding": 16
    },
    "plotOptions": {
      "area": {
        "marker": {
          "radius": 4,
          "fillColor": "#fff",
          "lineWidth": 2
        },
        "lineWidth": 2
      }
    },
    "series": [
      {
        "name": "Balance ($)",
        "type": "area",
        "data": [],
        "yAxis": 0,
        "color": "#7c3aed",
        "fillColor": {
          "linearGradient": {
            "x1": 0,
            "y1": 0,
            "x2": 0,
            "y2": 1
          },
          "stops": [
            [
              0,
              "#7c3aed33"
            ],
            [
              1,
              "#7c3aed05"
            ]
          ]
        },
        "lineColor": "#7c3aed",
        "marker": {
          "lineColor": "#7c3aed"
        }
      }
    ],
    "credits": {
      "enabled": false
    }
  };
  chartBalance = Highcharts.chart('container_balance', chartBalanceStructure);


});
  </script>
  <script type="application/javascript">
    console.log({{ DEBUG }},"<-:DEBUG");
    document.addEventListener('DOMContentLoaded', () => {

